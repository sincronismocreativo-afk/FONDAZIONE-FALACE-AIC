rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User states validation
    function isValidUserState(data) {
      return data.keys().hasAll(['activeTab', 'isChatOpen', 'updatedAt'])
        && data.keys().size() <= 4
        && data.activeTab is string && data.activeTab.size() <= 50
        && data.isChatOpen is bool
        && data.updatedAt is string && data.updatedAt.size() <= 50
        && (!data.keys().hasAny(['selectedBookForAi']) || (data.selectedBookForAi == null || (data.selectedBookForAi is string && data.selectedBookForAi.size() <= 100)));
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /states/{stateId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) 
          && isValidId(stateId)
          && isValidUserState(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
